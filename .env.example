# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# E-Mail (SMTP via nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Coloreo <noreply@deine-domain.de>"

# Claude
ANTHROPIC_API_KEY=

# Replicate (thematische Mal-Linienkunst)
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-schnell

# App — Prod: https://coloreo.shop · lokal: http://localhost:3100
NEXT_PUBLIC_SITE_URL=https://coloreo.shop
ADMIN_EMAILS=

# E-Mail-Lifecycle (Modul C)
CRON_SECRET=                 # schützt /api/cron/email (Vercel-Cron sendet x-vercel-cron)
UNSUB_SECRET=                # HMAC-Secret für Abmelde-Links (Fallback: Service-Role-Key)
WINBACK_WEEKS=6              # Inaktivitäts-Schwelle für Win-Back
WINBACK_COUPON=             # optionaler Gutscheincode in Win-Back-Mails
NEXT_PUBLIC_REVIEW_THRESHOLD=3   # Sterne erst ab so vielen echten Reviews
